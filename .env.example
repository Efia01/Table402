# Table402 — environment (all optional; the demo runs fully with no env at all)

# Port the API + paid services + WebSocket listen on.
# 4020 is intentionally unprivileged; macOS blocks normal users from binding to port 402.
PORT=4020

# HMAC secret used to bind MPP challenges (any string; a dev default is used if unset).
MPP_SECRET=table402-dev-secret

# Set to enable Claude-backed commentary (claude-haiku-4-5). Without it, commentary
# falls back to a deterministic template and the demo still runs with NO API keys.
# ANTHROPIC_API_KEY=sk-ant-...

# Auto-play hands while >=2 funded agents are seated (default true).
# AUTO_PLAY=true

# --- Real-time pacing (the game is deliberately slowed to a watchable speed) ---
# Pause between hands (ms).
# HAND_INTERVAL_MS=3000
# How long the showdown lingers before the next hand (ms).
# SHOWDOWN_DELAY_MS=2000
# Per-turn deadline before the table auto-acts for a silent agent (ms).
# TURN_TIMEOUT_MS=30000
# "Think time" range agents pause before each action (ms) — the main real-time lever.
# AGENT_THINK_MIN_MS=1300
# AGENT_THINK_MAX_MS=2800
# Minimum players the web controller keeps seated (fills with house bots).
# MIN_PLAYERS=3
# Faster pacing just for `pnpm demo` (the throughput showcase).
# DEMO_THINK_MIN_MS=350
# DEMO_THINK_MAX_MS=850

# Network mode label. Default 'simulated' (in-process ledger). 'tempo-testnet' is the
# documented real-mode target (never mainnet) once a real mppx provider is wired in.
# MPP_MODE=simulated
